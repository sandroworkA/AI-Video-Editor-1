        const fileInput = document.getElementById('fileInput');
        const processBtn = document.getElementById('processBtn');
        
        dropZone.onclick = () => fileInput.click();
        
        dropZone.ondragover = (e) => {
            e.preventDefault();
            dropZone.classList.add('dragover');
        };
        
        dropZone.ondragleave = () => dropZone.classList.remove('dragover');
        
        dropZone.ondrop = (e) => {
            e.preventDefault();
            dropZone.classList.remove('dragover');
            if (e.dataTransfer.files.length) {
                handleFile(e.dataTransfer.files[0]);
            }
        };
        
        fileInput.onchange = (e) => {
            if (e.target.files.length) handleFile(e.target.files[0]);
        };
        
        function handleFile(file) {
            selectedFile = file;
            dropZone.innerHTML = `<h2>✅ ${file.name}</h2><p>${(file.size/1024/1024).toFixed(1)} MB</p>`;
            processBtn.disabled = false;
        }
        
        async function startProcessing() {
            if (!selectedFile) return;
            
            const formData = new FormData();
            formData.append('video', selectedFile);
            formData.append('style', document.getElementById('styleSelect').value);
            formData.append('platform', document.getElementById('platformSelect').value);
            
            document.getElementById('progressContainer').style.display = 'block';
            processBtn.disabled = true;
            
            try {
                const response = await fetch('/process', { method: 'POST', body: formData });
                const data = await response.json();
                
                if (data.job_id) {
                    pollStatus(data.job_id);
                }
            } catch (error) {
                alert('Error: ' + error.message);
                processBtn.disabled = false;
            }
        }
        
        function pollStatus(jobId) {
            const interval = setInterval(async () => {
                const response = await fetch(`/status/${jobId}`);
                const data = await response.json();
                
                document.getElementById('progressFill').style.width = data.progress + '%';
                document.getElementById('statusText').textContent = 
                    data.status === 'analyzing' ? '🧠 AI analyzing content...' :
                    data.status === 'editing' ? '✂️ Editing video...' :
                    data.status === 'complete' ? '✅ Complete!' : 'Processing...';
                
                if (data.status === 'complete') {
                    clearInterval(interval);
                    showResult(data.report, jobId);
                } else if (data.status === 'error') {
                    clearInterval(interval);
                    alert('Processing failed: ' + data.error);
                    processBtn.disabled = false;
                }
            }, 1000);
        }
        
        function showResult(report, jobId) {
            document.getElementById('result').style.display = 'block';
            document.getElementById('originalVideo').src = URL.createObjectURL(selectedFile);
            document.getElementById('enhancedVideo').src = `/download/${jobId}`;
            document.getElementById('downloadBtn').href = `/download/${jobId}`;
            
            const statsDiv = document.getElementById('stats');
            statsDiv.innerHTML = `
                <div class="stat-box">
                    <div class="stat-value">${report.cuts_made}</div>
                    <div class="stat-label">Smart Cuts</div>
                </div>
                <div class="stat-box">
                    <div class="stat-value">${report.zooms_applied}</div>
                    <div class="stat-label">Dynamic Zooms</div>
                </div>
                <div class="stat-box">
                    <div class="stat-value">${Math.round(report.engagement_score)}</div>
                    <div class="stat-label">Avg Engagement</div>
                </div>
                <div class="stat-box">
                    <div class="stat-value">${(report.original_duration/60).toFixed(1)}m</div>
                    <div class="stat-label">Original Length</div>
                </div>
            `;
            
            processBtn.disabled = false;
            processBtn.textContent = '✨ Process Another Video';
        }
    </script>
</body>
</html>
"""

# Flask Routes
@app.route('/')
def index():
    return HTML_TEMPLATE

@app.route('/process', methods=['POST'])
def process():
    if 'video' not in request.files:
        return jsonify({'error': 'No video uploaded'}), 400
    
    file = request.files['video']
    if file.filename == '':
        return jsonify({'error': 'No file selected'}), 400
    
    # Generate job ID
    job_id = str(uuid.uuid4())
    ext = file.filename.rsplit('.', 1)[1].lower()
    input_path = os.path.join(app.config['UPLOAD_FOLDER'], f"{job_id}.{ext}")
    file.save(input_path)
    
    # Get parameters
    style = request.form.get('style', 'youtube')
    platform = request.form.get('platform', 'youtube')
    
    # Start processing thread
    thread = Thread(target=style_sync.process_video, args=(job_id, input_path, style, platform))
    thread.daemon = True
    thread.start()
    
    return jsonify({'job_id': job_id})

@app.route('/status/<job_id>')
def status(job_id):
    return jsonify(style_sync.active_jobs.get(job_id, {'status': 'unknown'}))

@app.route('/download/<job_id>')
def download(job_id):
    output_path = f"{app.config['OUTPUT_FOLDER']}/{job_id}_final.mp4"
    if os.path.exists(output_path):
        return send_file(output_path, as_attachment=True, download_name=f"stylesync_edit_{job_id[:8]}.mp4")
    return jsonify({'error': 'File not found'}), 404

if __name__ == '__main__':
    print("🎬 Starting StyleSync AI...")
    print("Open http://localhost:5000 in your browser")
    app.run(debug=True, host='0.0.0.0', port=5000, threaded=True)
