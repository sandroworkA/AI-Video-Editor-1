class StyleSyncApp:
    def __init__(self):
        self.active_jobs = {}
    
    def process_video(self, job_id, input_path, style='youtube', platform='youtube'):
        """Main processing pipeline"""
        try:
            self.active_jobs[job_id] = {'status': 'analyzing', 'progress': 0}
            
            # Phase 1-2: Analysis
            analyzer = ContentAnalyzer(input_path)
            decisions = analyzer.generate_edit_decisions(style=style)
            
            self.active_jobs[job_id] = {'status': 'editing', 'progress': 50}
            
            # Phase 3-5: Editing
            editor = VideoEditor(input_path, f"{app.config['OUTPUT_FOLDER']}/{job_id}_final.mp4")
            
            # Apply pipeline
            cut_video = editor.apply_cuts(decisions['cuts'])
            zoomed_video = editor.apply_zooms(cut_video, decisions['zooms'])
            audio_enhanced = editor.enhance_audio(zoomed_video)
            color_graded = editor.apply_color_grading(audio_enhanced, style='viral_pop')
            final_output = editor.platform_optimize(color_graded, platform)
            
            editor.cleanup()
            
            # Generate analysis report
            report = {
                'original_duration': analyzer.duration,
                'cuts_made': len(decisions['cuts']),
                'zooms_applied': len(decisions['zooms']),
                'engagement_score': np.mean(decisions['scores']),
                'output_file': final_output
            }
            
            self.active_jobs[job_id] = {
                'status': 'complete',
                'progress': 100,
                'report': report
            }
            
        except Exception as e:
            self.active_jobs[job_id] = {'status': 'error', 'error': str(e)}
            print(f"[Error] Job {job_id}: {e}")

