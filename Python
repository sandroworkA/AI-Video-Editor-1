class ContentAnalyzer:
    def __init__(self, video_path):
        self.video_path = video_path
        self.cap = cv2.VideoCapture(video_path)
        self.fps = self.cap.get(cv2.CAP_PROP_FPS)
        self.total_frames = int(self.cap.get(cv2.CAP_PROP_FRAME_COUNT))
        self.duration = self.total_frames / self.fps
        self.width = int(self.cap.get(cv2.CAP_PROP_FRAME_WIDTH))
        self.height = int(self.cap.get(cv2.CAP_PROP_FRAME_HEIGHT))
        
        # Analysis storage
        self.scene_scores = []
        self.audio_data = {}
        self.engagement_map = []
        
    def analyze_visual_content(self):
        """Phase 1.1: Visual Analysis Engine"""
        print("[AI] Analyzing visual content...")
        prev_frame = None
        scene_changes = []
        motion_scores = []
        face_engagement = []
        
        frame_idx = 0
        while True:
            ret, frame = self.cap.read()
            if not ret:
                break
                
            # Scene Detection (Frame difference)
            if prev_frame is not None:
                diff = cv2.absdiff(frame, prev_frame)
                diff_score = np.mean(diff)
                if diff_score > 30:  # Scene change threshold
                    scene_changes.append(frame_idx / self.fps)
            
            # Motion Analysis (Optical flow)
            if prev_frame is not None:
                gray = cv2.cvtColor(frame, cv2.COLOR_BGR2GRAY)
                prev_gray = cv2.cvtColor(prev_frame, cv2.COLOR_BGR2GRAY)
                flow = cv2.calcOpticalFlowPyrLK(prev_gray, gray, None, None)
                if flow[0] is not None:
                    motion_mag = np.mean(np.abs(flow[0]))
                    motion_scores.append(min(motion_mag / 10, 100))
                else:
                    motion_scores.append(0)
            else:
                motion_scores.append(0)
            
            # Facial Engagement Detection
            face_cascade = cv2.CascadeClassifier(cv2.data.haarcascades + 'haarcascade_frontalface_default.xml')
            gray = cv2.cvtColor(frame, cv2.COLOR_BGR2GRAY)
            faces = face_cascade.detectMultiScale(gray, 1.1, 4)
            
            if len(faces) > 0:
                # Simulate engagement based on face size (closer = more engaging) and position
                face_area = max([w*h for (x,y,w,h) in faces])
                engagement = min(face_area / (self.width * self.height) * 1000, 100)
                face_engagement.append(engagement)
            else:
                face_engagement.append(0)
            
            prev_frame = frame.copy()
            frame_idx += 1
            
            # Progress indicator every 30 frames
            if frame_idx % 30 == 0:
                progress = (frame_idx / self.total_frames) * 100
                print(f"[AI] Visual analysis: {progress:.1f}%")
        
        self.cap.set(cv2.CAP_PROP_POS_FRAMES, 0)  # Reset to beginning
        
        return {
            'scene_changes': scene_changes,
            'motion_scores': motion_scores,
            'face_engagement': face_engagement
        }
    
    def analyze_audio_content(self):
        """Phase 1.2: Audio Intelligence Layer"""
        print("[AI] Analyzing audio content...")
        
        # Extract audio to wav
        audio_path = self.video_path.replace('.mp4', '_temp.wav')
        try:
            (
                ffmpeg
                .input(self.video_path)
                .output(audio_path, ac=1, ar=16000)
                .run(overwrite_output=True, quiet=True)
            )
            
            # Load audio
            y, sr = librosa.load(audio_path, sr=16000)
            
            # Silence Detection
            intervals = librosa.effects.split(y, top_db=20)
            silence_periods = []
            prev_end = 0
            
            for start, end in intervals:
                if start > prev_end:
                    silence_periods.append((prev_end/sr, start/sr))
                prev_end = end
            
            # Energy/RMS for engagement mapping
            rms = librosa.feature.rms(y=y)[0]
            # Normalize to 0-100
            rms_normalized = (rms / np.max(rms)) * 100 if np.max(rms) > 0 else rms
            
            # Speech rate (zero crossing rate)
            zcr = librosa.feature.zero_crossing_rate(y)[0]
            
            self.audio_data = {
                'silence_periods': silence_periods,
                'rms_energy': rms_normalized.tolist(),
                'speech_activity': (zcr > 0.01).tolist(),
                'duration': len(y) / sr
            }
            
            os.remove(audio_path)
            
        except Exception as e:
            print(f"[AI] Audio analysis error: {e}")
            self.audio_data = {
                'silence_periods': [],
                'rms_energy': [50] * int(self.duration),
                'speech_activity': [True] * int(self.duration),
                'duration': self.duration
            }
        
        return self.audio_data
    
    def calculate_content_scores(self):
        """Phase 1.3: Content Scoring Algorithm (0-100 scale)"""
        print("[AI] Calculating content scores...")
        
        visual = self.analyze_visual_content()
        audio = self.analyze_audio_content()
        
        scores = []
        seconds = int(self.duration)
        
        for sec in range(seconds):
            score = 50  # Base score
            
            # Visual engagement contribution (30%)
            if sec < len(visual['face_engagement']):
                face_score = visual['face_engagement'][sec]
                score += face_score * 0.3
            
            # Motion contribution (20%)
            if sec < len(visual['motion_scores']):
                motion_score = visual['motion_scores'][sec]
                score += motion_score * 0.2
            
            # Audio energy contribution (30%)
            if sec < len(audio['rms_energy']):
                energy = audio['rms_energy'][sec]
                score += energy * 0.3
            
            # Silence penalty (Heavy reduction)
            for start, end in audio['silence_periods']:
                if start <= sec <= end:
                    silence_duration = end - start
                    if silence_duration > 1.5:
                        score -= 50  # Dead air penalty
                    elif silence_duration > 0.5:
                        score -= 20
            
            # Scene change bonus (new scenes are interesting)
            if any(abs(sc - sec) < 0.5 for sc in visual['scene_changes']):
                score += 10
            
            # Normalize to 0-100
            score = max(0, min(100, score))
            scores.append(score)
        
        self.engagement_map = scores
        return scores
    
    def generate_edit_decisions(self, style='youtube'):
        """Phase 2: Intelligent Editing Decisions"""
        print(f"[AI] Generating {style} style edit decisions...")
        
        scores = self.calculate_content_scores()
        cuts = []
        zooms = []
        protected_segments = []
        
        # Protect first 3 seconds (hook) and last 5 seconds (CTA)
        protected_segments.append((0, 3))
        protected_segments.append((self.duration - 5, self.duration))
        
        # Protect high engagement peaks (>85)
        i = 0
        while i < len(scores):
            if scores[i] > 85:
                start = i
                while i < len(scores) and scores[i] > 70:
                    i += 1
                protected_segments.append((start, i))
            i += 1
        
        # Determine cut thresholds based on style
        if style == 'tiktok':
            min_segment = 1.0
            max_segment = 3.0
            cut_threshold = 40
        elif style == 'cinematic':
            min_segment = 8.0
            max_segment = 15.0
            cut_threshold = 25
        else:  # youtube
            min_segment = 3.0
            max_segment = 7.0
            cut_threshold = 35
        
        # Generate cuts
        current_time = 0
        while current_time < self.duration - max_segment:
            segment_end = current_time + min_segment
            
            # Look for cut point (lowest score in window)
            best_cut = None
            best_score = 100
            
            search_end = min(current_time + max_segment, self.duration - 5)
            
            for t in np.arange(segment_end, search_end, 0.5):
                sec_idx = int(t)
                if sec_idx >= len(scores):
                    break
                
                # Check if protected
                is_protected = any(start <= t <= end for start, end in protected_segments)
                
                if not is_protected and scores[sec_idx] < best_score:
                    best_score = scores[sec_idx]
                    best_cut = t
            
            if best_cut and best_score < cut_threshold:
                cuts.append(best_cut)
                
                # Add zoom if score is high (80+) before cut (jump cut mask)
                if best_score > 80:
                    zooms.append({
                        'time': best_cut - 0.3,
                        'type': 'in',
                        'scale': 1.08,
                        'duration': 0.3
                    })
                
                current_time = best_cut
            else:
                current_time += min_segment
        
        # Add zooms for high engagement segments (Phase 3.1)
        for i, score in enumerate(scores):
            if score > 90:
                # Check if not already has zoom
                if not any(abs(z['time'] - i) < 1 for z in zooms):
                    zooms.append({
                        'time': i,
                        'type': 'in',
                        'scale': 1.25,
                        'duration': 0.8
                    })
        
        return {
            'cuts': cuts,
            'zooms': zooms,
            'protected_segments': protected_segments,
            'scores': scores
        }

